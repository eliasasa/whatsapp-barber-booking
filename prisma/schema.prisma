generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Availability {
  id        String   @id @default(uuid())
  weekday   Int      @unique
  startTime String   
  endTime   String   

  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(uuid())
  name      String?
  notes     String?
  botDisabled Boolean @default(false)
  phone     String?  @unique
  createdAt DateTime @default(now())

  appointments Appointment[]
}

model Service {
  id           String        @id @default(uuid())
  name         String
  duration     Int
  price        Int?
  paused       Boolean       @default(false)

  appointments Appointment[]
}

model Appointment {
  id        String   @id @default(uuid())
  startAt   DateTime
  endAt     DateTime
  status    AppointmentStatus @default(CONFIRMED)

  address   String?
  notes     String?

  clientId  String
  serviceId String

  client    Client  @relation(fields: [clientId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())

  @@index([startAt, endAt])
}

model BotMessage {
  id        String       @id @default(uuid())
  key       BotMessageKey @unique
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model BotState {
  id        String   @id @default(uuid())
  paused    Boolean  @default(false)
  lastPing  DateTime?

  updatedAt DateTime @updatedAt
}

model AvailabilityBlock {
  id        String   @id @default(uuid())
  startAt   DateTime
  endAt     DateTime
  reason    String?

  createdAt DateTime @default(now())
}

enum AppointmentStatus {
  CONFIRMED
  CANCELED
}

enum BotMessageKey {
  GREETING
}

