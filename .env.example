PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
WAHA_API_URL=http://localhost:3001
WAHA_API_KEY=your_api_key_here
BOT_NAME=Elias

# Auth do painel
# Obrigatorio: segredo para assinar o JWT do login
AUTH_JWT_SECRET=coloque_uma_chave_longa_e_aleatoria_aqui

# Opcional: tempo de expiracao do token
AUTH_JWT_EXPIRES_IN=12h

# Opcional: chave para criar o primeiro admin via POST /auth/setup
AUTH_SETUP_KEY=uma_chave_extra_secreta

# Opcional: cria/atualiza o primeiro admin no seed quando esses dois estiverem preenchidos
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=SenhaForte123
ADMIN_NAME=Admin

# WAHA - COMMON
WHATSAPP_DEFAULT_ENGINE=WEBJS
WAHA_LOG_LEVEL=info
WAHA_LOG_FORMAT=JSON

# Session
WHATSAPP_START_SESSION=default
WHATSAPP_RESTART_ALL_SESSIONS=false

# Webhook
WHATSAPP_HOOK_URL=http://host.docker.internal:3000/webhook/waha
WHATSAPP_HOOK_EVENTS=session.status,message

# WAHA_DASHBOARD_USERNAME=admin
# WAHA_DASHBOARD_PASSWORD=admin